# ─── Deployment mode ─────────────────────────────────────────────────────────
# Profiles (comma-separated, passed to `docker compose --profile`):
#   local  — Ollama runs on the host (default; uses GPU/Metal)
#   cloud  — Ollama runs as a container alongside the rest of the stack
#   mcp    — adds the mcpo MCP→OpenAPI proxy
# Combine as needed, e.g. PROFILES=cloud,mcp
PROFILES=local

# ─── Model ───────────────────────────────────────────────────────────────────
# Browse models at https://ollama.com/library
#   mistral          — 7B, Apache-2.0, supports tool calling (default)
#   llama3.1:8b      — 8B, alternative, also reliable for tools
#   llama3.2         — 3B, faster but tool calling is unreliable
#   gpt-oss:20b      — larger, better tool calling on capable machines
MODEL=mistral

# ─── Ports ───────────────────────────────────────────────────────────────────
WEBUI_PORT=3000
N8N_PORT=5678

# ─── Secrets ─────────────────────────────────────────────────────────────────
# Generated automatically by setup scripts; leave blank in the example file.
WEBUI_SECRET_KEY=
